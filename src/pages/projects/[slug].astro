---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import ProjectTagIcons from "@/components/ProjectTagIcons.astro";
import { ExternalLinkIcon, Github } from "@lucide/astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).filter(
    (project) => !project.data.draft,
  );

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { Content } = await project.render();
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  backToLink={{ text: "projects", href: "/projects" }}
>
  <div class="mx-auto w-full max-w-5xl px-6 py-16">
    <article>
      <header
        class="mb-16 opacity-0 animate-fade-in-up"
        style="animation-delay: 0s;"
      >
        <div class="flex items-start justify-between gap-4">
          <h1 class="min-w-0 text-2xl tracking-tight text-text">
            {project.data.title}
          </h1>
        {
          (project.data.liveUrl || project.data.repoUrl) && (
            <div class="flex shrink-0 items-center gap-0">
              {project.data.liveUrl && (
                <a
                  href={project.data.liveUrl}
                  target="_blank"
                    rel="noopener noreferrer"
                    title="Live"
                    class="rounded-md p-2 text-muted transition-colors hover:text-accent outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
                  >
                    <ExternalLinkIcon size={24} />
                    <span class="sr-only">Live</span>
                  </a>
                )}
                {project.data.repoUrl && (
                  <a
                    href={project.data.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    title="Repo"
                    class="rounded-md p-2 text-muted transition-colors hover:text-accent outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50"
                  >
                    <Github size={24} />
                    <span class="sr-only">Repository</span>
                  </a>
                )}
              </div>
            )
          }
        </div>
        <p class="mt-2 text-sm text-muted">
          {project.data.summary}
        </p>
        {
          project.data.tags.length > 0 && (
            <div class="mt-4">
              <ProjectTagIcons tags={project.data.tags} />
            </div>
          )
        }
      </header>

      <div class="prose prose-invert mt-10 max-w-none">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
