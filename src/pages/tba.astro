---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteTitle = "TBA";
const description = "Hier entsteht gerade etwas Neues";
---

<BaseLayout title={siteTitle} description={description} backToLink={false}>
  <div class="flex min-h-screen flex-col items-center justify-center px-6">
    <div class="text-center">
      <h1
        class="text-6xl font-light tracking-tighter text-text opacity-0 animate-fade-in-up sm:text-7xl"
        style="animation-delay: 0s;"
      >
        TBA
      </h1>
      <p
        class="mt-4 text-sm tracking-wider text-muted opacity-0 animate-fade-in-up"
        style="animation-delay: 0.1s;"
      >
        Hier passiert bald was.
      </p>
      <a
        href="/"
        class="mt-8 inline-block text-subtle opacity-0 transition-colors duration-200 animate-fade-in-up hover:text-text"
        style="animation-delay: 0.2s;"
      >
        Zurück
      </a>
    </div>
  </div>
</BaseLayout>
