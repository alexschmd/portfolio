---
import type { CollectionEntry } from "astro:content";
import { ExternalLinkIcon } from "@lucide/astro";
import GithubIcon from "@/assets/github.svg.astro";
import ProjectTagIcons from "@/components/ProjectTagIcons.astro";

type Props = {
  project: CollectionEntry<"projects">;
  class?: string;
  style?: string;
};

const {
  project,
  class: className,
  style,
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const baseClass =
  "group relative rounded-lg border border-white/5 bg-white/0 p-4 transition-[color,box-shadow,border-color,background-color] duration-200 hover:border-accent/30 hover:bg-surface hover:ring-[3px] hover:ring-accent/20 focus-within:border-accent/40 focus-within:ring-[3px] focus-within:ring-accent/40";
---

<li {...rest} class:list={[baseClass, className]} style={style}>
  <div class="flex items-start justify-between gap-4">
    <a
      href={`/projects/${project.slug}`}
      class="min-w-0 flex-1 text-subtle transition-colors duration-200 hover:text-text"
    >
      <h3 class="text-base">{project.data.title}</h3>
      <p class="mt-1 text-sm text-muted">{project.data.summary}</p>
      {
        project.data.tags.length > 0 && (
          <div class="mt-3">
            <ProjectTagIcons tags={project.data.tags} />
          </div>
        )
      }
    </a>

    <div class="flex shrink-0 flex-col items-end gap-2 self-stretch">
      {
        project.data.date && (
          <time
            class="text-right text-xs text-muted"
            datetime={project.data.date.toISOString()}
          >
            {project.data.date.toLocaleDateString("de-DE")}
          </time>
        )
      }

      {
        (project.data.liveUrl || project.data.repoUrl) && (
          <div class="mt-auto flex items-center gap-0 -mr-2 -mb-2">
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                title="Live"
                class="p-2 transition-colors hover:border-accent/30 hover:text-accent"
              >
                <ExternalLinkIcon size={16} />
                <span class="sr-only">Live</span>
              </a>
            )}
            {project.data.repoUrl && (
              <a
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                title="Repository"
                class="p-2 transition-colors hover:border-accent/30 hover:text-accent"
              >
                <span class="block h-4 w-4">
                  <GithubIcon />
                </span>
                <span class="sr-only">Repository</span>
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</li>
