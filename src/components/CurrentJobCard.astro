---
interface Props {
  company: string;
  companyUrl?: string | null;
  title: string;
  start: string | Date;
  end?: string | Date | null;
  description: string;
  Logo?: any;
  imageSrc?: string | null;
  imageAlt?: string;
  variant?: "full" | "compact";
}

const {
  company,
  companyUrl = null,
  title,
  start,
  end = null,
  description,
  Logo = null,
  imageSrc = null,
  imageAlt = "",
  variant = "full",
} = Astro.props;

function toDate(value: string | Date): Date {
  if (value instanceof Date) return value;

  const trimmed = value.trim();

  if (/^\d{4}-\d{2}$/.test(trimmed)) {
    const [year, month] = trimmed.split("-").map(Number);
    return new Date(Date.UTC(year, month - 1, 1));
  }

  if (/^\d{4}-\d{2}-\d{2}$/.test(trimmed)) {
    const [year, month, day] = trimmed.split("-").map(Number);
    return new Date(Date.UTC(year, month - 1, day));
  }

  const parsed = new Date(trimmed);
  if (!Number.isNaN(parsed.getTime())) return parsed;

  return new Date();
}

function formatMonthYear(date: Date) {
  return new Intl.DateTimeFormat("de-DE", { month: "short", year: "numeric" })
    .format(date)
    .replace(".", "");
}

function diffInMonths(from: Date, to: Date) {
  const fromY = from.getUTCFullYear();
  const fromM = from.getUTCMonth();
  const fromD = from.getUTCDate();

  const toY = to.getUTCFullYear();
  const toM = to.getUTCMonth();
  const toD = to.getUTCDate();

  let months = (toY - fromY) * 12 + (toM - fromM);
  if (toD < fromD) months -= 1;
  return Math.max(0, months);
}

function formatDuration(totalMonths: number) {
  if (totalMonths <= 0) return "seit kurzem";
  const years = Math.floor(totalMonths / 12);
  const months = totalMonths % 12;

  const parts: string[] = [];
  if (years > 0) parts.push(`${years} ${years === 1 ? "Jahr" : "Jahre"}`);
  if (months > 0) parts.push(`${months} ${months === 1 ? "Monat" : "Monate"}`);
  return parts.join(" ");
}

const startDate = toDate(start);
const endDate = end ? toDate(end) : null;
const now = new Date();
const durationMonths = diffInMonths(startDate, endDate ?? now);

const rangeLabel = `${formatMonthYear(startDate)} – ${endDate ? formatMonthYear(endDate) : "Heute"}`;
const durationLabel = formatDuration(durationMonths);
const isCompact = variant === "compact";

const fallbackText = company
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase())
  .join("");
---

<div class={`relative pl-8 ${isCompact ? "py-2" : "py-3"}`}>
  <span
    aria-hidden="true"
    class="absolute bottom-0 left-2 top-0 w-px bg-white/10"
  ></span>
  <span
    aria-hidden="true"
    class="absolute left-2 top-4 h-3.5 w-3.5 -translate-x-[6.5px] rounded-full border border-white/25 bg-void"
  ></span>

  <div class="min-w-0">
    <div class="text-xs tracking-wide text-muted">{rangeLabel} · {durationLabel}</div>

    <div class={`mt-3 flex gap-3 ${isCompact ? "items-start" : "items-center"}`}>
      <div class="shrink-0">
        <div
          class={`overflow-hidden rounded-lg bg-void/60 ${isCompact ? "h-10 w-10" : "h-12 w-12"} ${Logo ? "" : "border border-white/10"}`}
        >
          {
            Logo ? (
              <div class="flex h-full w-full items-center justify-center [&>svg]:h-auto [&>svg]:max-h-full [&>svg]:w-full">
                <Logo />
              </div>
            ) : imageSrc ? (
              <img
                src={imageSrc}
                alt={imageAlt}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            ) : (
              <div class="grid h-full w-full place-items-center bg-accent/10 text-xs font-medium text-accent">
                {fallbackText || "JOB"}
              </div>
            )
          }
        </div>
      </div>

      <div class="min-w-0 flex-1">
        <div
          class={`min-w-0 font-medium text-text ${isCompact ? "text-base" : "text-xl leading-tight"}`}
        >
          {title}
        </div>
        {
          companyUrl ? (
            <a
              href={companyUrl}
              target="_blank"
              rel="noopener noreferrer"
              title={`${company} öffnen`}
              class="mt-1 inline-block max-w-full truncate text-sm text-subtle underline decoration-dashed decoration-transparent underline-offset-4 transition-[color,text-decoration-color] hover:text-text hover:decoration-accent"
            >
              {company}
            </a>
          ) : (
            <div class="mt-1 truncate text-sm text-subtle">{company}</div>
          )
        }
      </div>
    </div>

    <p
      class={`mt-4 text-muted ${isCompact ? "text-xs leading-relaxed [display:-webkit-box] [-webkit-line-clamp:2] [-webkit-box-orient:vertical] overflow-hidden" : "text-sm leading-relaxed"}`}
    >
      {description}
    </p>
  </div>
</div>
