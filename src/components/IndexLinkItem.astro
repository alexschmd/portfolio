---
import { ChevronRight } from "@lucide/astro";

interface Props {
  href: string;
  label: string;
  style?: string;
}

const { href, label, style } = Astro.props;
---

<div class="group opacity-0 animate-fade-in-up" style={style}>
  <a
    href={href}
    class="relative flex w-full items-start justify-between gap-4 py-3"
  >
    <div class="min-w-0 flex-1">
      <div class="text-subtle transition-colors duration-200 group-hover:text-text">
        {label}
      </div>
    </div>
    <span class="mt-1 shrink-0 text-muted opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0.5">
      <ChevronRight size={16} />
    </span>
    <span class="absolute bottom-2 left-0 h-px w-0 bg-accent/40 transition-all duration-300 ease-out group-hover:w-full" />
  </a>
  <div class="mt-2 text-sm text-muted">
    <slot />
  </div>
</div>
